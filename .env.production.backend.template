# Production Environment Variables for Backend

# ============================================
# CRITICAL - MUST UPDATE FOR PRODUCTION
# ============================================

# JWT Secret Key (GENERATE NEW ONE!)
# Generate: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY="REPLACE_WITH_NEW_32_CHAR_RANDOM_STRING"

# MongoDB Production Database
# Get from MongoDB Atlas: https://cloud.mongodb.com
MONGO_URL="mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority"
DB_NAME="startup_intel_production"

# CORS Origins (Your Frontend Domain)
# Example: "https://app.startupintel.com,https://startupintel.com"
CORS_ORIGINS="https://YOUR_DOMAIN.com"

# Email Service (Resend)
# Get API Key: https://resend.com/api-keys
RESEND_API_KEY="re_YOUR_RESEND_API_KEY"
SENDER_EMAIL="onboarding@yourdomain.com"

# Frontend URL
FRONTEND_URL="https://YOUR_DOMAIN.com"

# ============================================
# OPTIONAL - Can Keep Defaults
# ============================================

# Rate Limiting
RATE_LIMIT_ENABLED="true"
RATE_LIMIT_PER_MINUTE="60"
